
do --- tonumber int
  local x = 0
  for i=1,100 do x = x + tonumber(i) end
  assert(x == 5050)
end

do --- tonumber float
  local x = 0
  for i=1.5,100.5 do x = x + tonumber(i) end
  assert(x == 5100)
end

do --- tostring int / tonumber
  local t = {}
  for i=0,100do t[i] = tostring(i) end
  local x = 0
  for i=1,100 do assert(type(t[i]) == "string"); x = x + tonumber(t[i]) end  
  assert(x == 5050)
end

