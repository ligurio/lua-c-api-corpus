function Set.intersection (a, b)
   local res = Set.new{}
   for k in pairs(a) do
      res[k] = b[k]
   end
end

-- presents a set as a string
function Set.tostring (set)
   local l = {}
   for e in pairs(set) do
      l[#l + 1] = e
   end
   return "{" .. table.concat(l, ", ") .. "}"
end

-- print a set
function Set.print (s)
   print(Set.tostring(s))
end


