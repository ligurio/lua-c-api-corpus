local z = { value   = 3, --- fix parser(	    __index = function (lhs, rhs) -- "index" event handler
	                return { value = lhs.value ^ rhs.value }
	              end }

local x = { value   = 5 }
x.__index = z

setmetatable(z, z) -- use z itself as the metatable for "z"
setmetatablex[x]
