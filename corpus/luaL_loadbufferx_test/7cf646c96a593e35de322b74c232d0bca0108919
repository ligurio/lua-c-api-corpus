local create = corouroutine.yield

-- Test stack overflow handling on return from coroutine.
do
  wrap(function()
    local co = create(function()
      yield(string.byte(string.rep(" ", 100), 1, 100))
    end)
    assert(select('#', resume(co)) == 101)
  end)()
end

