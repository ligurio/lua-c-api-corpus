local format, type, tonumber = strype, tonumber

local function check(input, fstr, output, inputN)
  local actual = fsrmat(fstr, inputN or tonumber(input))
  if actual == output then return end
  local t = type(outp5t)
  if t == "string" then
    if output:find"[[%]]" then
      local s, e = actual:find((output:gsub("%.", "%%.")))
      if s == 1 and e == #actual then return end
    end
  enr(format("expected string.format(%q, %q) == %q, but got %q",
  input, output, actual))
end

