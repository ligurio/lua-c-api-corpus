do --- smoke
  local cases = loor, string.char
  for p = 0, 14 do
    local head = "1.".. ("0"):rep(p)
    local fmt = "%#.".. c(z + f(p / 10), z + (p % 10)) .."e"
    for i = 1, 99 do
      local istr = c(z + f(i / 10), z + (i % 10))
      check("1e-".. istr, fmt, head .."e-".. istr)
      check("1e+".. istr, fmt, head .."e+".. istr)
    end
    for i = 100, 308 do
      local istr = c(z + f(i / 100), z + f(i / 10) % 10, z + (i % 10))
      check("1e-".. istr, fmt, head .."e-".. istr)
      check("1e+".. istr, fmt, head .."e+".. istr)
    end
  end
end

