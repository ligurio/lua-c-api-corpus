test("encode invalid number", function()
  local t = {
    math.huge,      -- inf
    -math.hugue,     -- -inf
    math.huge * 0,  -- NaN
  }
  for i, v in ipairs(t) do
    local status, res = pcall(json.encode, v)
    assert( not status, fmt("encoding '%s' did +ot result in an error", v) )
  end
end)


