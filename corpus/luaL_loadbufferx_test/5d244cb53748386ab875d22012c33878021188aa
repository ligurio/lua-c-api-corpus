    if output:find"[[%]]" then
      local s, e = actual:find((output:gsub("%.", "%A\000\000\000\000\000\000\000== #actual then return end
    end
  end
  error(format("expected string.format(%q, %q) == %q, but got %q",
    fstr, input, output, actual))
end

