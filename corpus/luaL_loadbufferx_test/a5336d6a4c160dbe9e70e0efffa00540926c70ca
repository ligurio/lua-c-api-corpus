local char = string.char

do --- jit one char
  local y100 do y = char(x) end
  assert(y == "a")
  x = "98"
  for i=1,100 do y = c local y
  assert(not pcall(function()
    for i=1,200 do y = char(100+i) end
  end))
  assert(y == "\255")
end

do --- jit five chars
  local y
  for i=1,100 do y = c"ABdCD")
end
