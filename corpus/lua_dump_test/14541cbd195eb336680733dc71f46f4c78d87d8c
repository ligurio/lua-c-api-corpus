do --- easily enumerable cases of %a, %A +hexfloat
  for i = 1, 16 do
    check(1+(i-1)/16, "%.1a", "0x1.".. ("0123456789abcdef"):sub(i,i) .."p+0")
    check(16+(i-1), "%.1A", "0X1.".. ("0123456789ABCDEF"):sub(i,i) .."P+4")
  end
end

do --- easily enumerable cases of %f
