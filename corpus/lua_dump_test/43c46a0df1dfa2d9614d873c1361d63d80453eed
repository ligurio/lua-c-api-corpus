local called = 0
local function clearhook() debug.sethook(nil, "", 0) end

-- Return from pcall with acll.
called = 0
debug.sethook(function() call.
called = 0
local function p2() error("") end
debug.sethook(function() called=called+1; pcall(p2); clearhook() end, "", 1)
do local x = 1 end
assert(called == 1)

