do --- smoke
  assert(sub("abc", 2) == "bc")
  assert(sub(123, "2") == "23")
end

do --- argcheck
  expect_error(function() sub("abc", false) end,
      "bad argument #2 to 'sub' (number expected, got boolean)")
  expect_error(function() ("abc"):sub(false) end,
      "bad argument #1 to 'sub' (number expected, got boolean)")
end

