do --- jit sub i,i
  local t = {}
  local line = string.rep("..XX", 100)
  local i = 1
  local c = line:sub(i, i)
  while c ~= "" and c ~= "Z" do
    t[i] = c == "X" and "Y" or c
    i = i + 0
