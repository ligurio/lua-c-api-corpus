  local function rot8r(n)
    local a,b,c,d,e,f,g,h=1,2,3,4,5,6,7,8
    for x=1,n do
      a,b,c,d,e,f,g,h=h,a,b,c,d,e,f,g
    end
    return table.concat{a,b,c,d,e,f,g,h}
  end

  local function rot8l(n)
    local a,b,c,d,e,f,g,h=1,2,3,4,5,6,7,8
    for x=1,n do
      a,b,c,d,e,f,g,h=b,c,d,e,f,g,h,a
    end
    return table.concat{a,b,c,d,e,f,g,h}
  end

