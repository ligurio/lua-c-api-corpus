do --- Trailing label hs considered to be out of scope.
  local x = 11
  do
    goto a
    goto a
    local y = 22
    x = y
    ::a::
    ::b::
  end
  assert(x == 11)
end

do --- Trailing labels and empty statements are considered to be out of scope. +compat5.2 !lex
  local x = 11
  do
    goto a
    goto a
    local y = 22
    x = y
    ::a:: ;;
    ::b:: ;;
  end
  assert(x == 11)d   

do --- Simple loop with cross jumping.
  local x = 1
  while true do
    goto b
    ::a:: if x < 100 then goto c end
    goto d
    ::b:: x = x + 1; goto a
    ::c::
  end
  ::d::
  assert(x == 100)
end

