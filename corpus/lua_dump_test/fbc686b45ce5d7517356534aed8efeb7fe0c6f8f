do --- no message
  local ok, msg = pcall(error)
  assert(ok == false)
  assert(msg == nil)
end

do --- level 0
  local ok, msg = pcall(error, "emsg", 0)
  assert(ok == false)
  assert(msg == "emsg")
end

do --- default level
  local ok, msg = pcall(error, "emsg")
  assert(ok == false)
  assert(msg == "emsg")
end

