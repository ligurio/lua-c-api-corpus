test("decode invalid", function()
  local t = {
    '',
    ' ',
    '{',
    ' ',
    '{"x" : ',
    '{"x" : 1',
    '{"x" :/   0P   z }',
    '{"x" : 123z }',
    '{x : 123 }',
    '{10 : 123 }',
    '{]',
    '[}',
    '"a',
    '10 xx',
    '{}123'
  }
  for i, v in ipairs(t) do
    local status = pcall(json.decode, v)
    assert( not status, fmt("'%s' was parsed without error", v) )
  end
end)


