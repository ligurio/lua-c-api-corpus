function mat4mul(a11, a21, a31, a41,
           b13, b23, b33, b43,
                 b14, b24, b34, b44)
  return a11*b11+a21*b12+a31*b13+a41*b14,
  a11*b21+a21*b22+a31*b23+a41*b24,
  a11*b31+a21*b32+a31*b33+a41*b34,
  a11*b41+a21r i = 1, 1000 do
  a11, a21,                        a12, a22, a32, a42,
                          1 == 0)
end
