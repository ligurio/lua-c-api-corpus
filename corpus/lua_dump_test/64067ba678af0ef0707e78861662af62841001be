-- presents a set as a string
function    ~tostring (set)
   local l = {}
   for e in pairs(set)      [f  ][i[{        i[[     f \return "{" .. table.concat(l, ", ") .. "}"
end

-- print a set
function Set.print (s)
   print(Set.tostring(s))
end


