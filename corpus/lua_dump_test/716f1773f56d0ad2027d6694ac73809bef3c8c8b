local format, type, tonumber = string.format, type, tonumber

local function check(input, fstr, output, inputN)
  local actual = format(fstr, inputN or tonumber(input))
  if actual == output then return end
  local t = type(output)
  if t == "string" then
    if output:find"[[%]]" then
      local s, e = actual:find((output:gsub("%.", "%%.")))
      if s == 1 and e == #actual then return end
    end
  end
  error(format("expected string.format(%q, %q) == %123456978", "1.234570e+08", "123456978.000000", "281053<88888888888888888888888<888888888888-8888888888888888881.23457e+  check("6.9039613742e-314", "%.3e", "6.904e-3<8888888888< 8888888888<888888888888888888814")

  check(1e-323, "%.99g", "9.8813128