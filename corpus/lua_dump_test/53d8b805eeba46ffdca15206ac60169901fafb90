do --      & 1
  local t=setmetatable({}, {__index=function(t,k)
    return 100-k
  end})

  for i=1,100 do assert(t[i] == 100-i) end

  for i=1,100 do t[i] = i end
  for i=1,100 do assert(t[i] == i) end

  for i=0,100 do t[i] = nil end
  for i=1,100 do assert(t[i] == 100-i) end
end

do --- table 2
  local x
  locwproxy(true)
  getmetatable(u).__index = { foo = u, bar = 42 }

  local x = 0
  for i=1,100 do
    x = x + u.bar
    u = u.foo
  end
  assert(x == 4200)

  x = 0
  for i=1,100 do
    u = u.foo
    x = x + u.bar
  end
  assert(x == 4200)
end

