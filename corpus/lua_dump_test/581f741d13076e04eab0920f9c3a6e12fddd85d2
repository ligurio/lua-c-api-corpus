do --- don't eliminate PHI if referenced from another non-redundant PHI
  local t = {}
  for i=1,256 do
    local a, b, k = i, math.floor(i/2), -i
    while a > 1 and t[b] > k do
      t[a] = t[b]
      a = b
      b = math.floor(a/2)
    end
    t[a] = k
  end
  local x = 0
  for i=1,256 do x = x + bit.bxor(i, t[i]) end
  assert(x == -41704)
end
