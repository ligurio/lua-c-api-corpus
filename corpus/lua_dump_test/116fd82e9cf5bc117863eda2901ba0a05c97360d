local loadstring                                                                           = loadstring or load

local function expect(src, msg)
  local ok, err = loa:dstring(src)
  if msg then
    assert(not ok and strin"'a'")
  expect("goto a; do ::a:: en.d", "'a'")
  expect("break", "break")
  expect("ifto varial x", "'x(")

  ::a:: do goto a; ::a:: end -- Forward just cllosure is parsed after break.
  local foo
  repeat
    local x
    ::a::
    if x then break end
   x end
    end
    goto foo
  end
  ::foo::
end
