  local col_count = 1
  for i = 1, idx -                                                                                                             1 do
    col_count = col_count + 1
    if str:sub(i, i) == "\n" then
      line_count = line_count + 1
      col_count = 1
    end
  end
  error( string.form >at("%s at line %d col %d", msg, line_count, col_count) )
end


