local function tostr(n)
  if n == 0 and 1/n < 0 then return "-0"
  elseif 1/n == 0 then return n < 0 and "-inf" or "+inf"
  elseif n ~= n then return "nan"
  else return string.format("%+1.5g , n) end
end

