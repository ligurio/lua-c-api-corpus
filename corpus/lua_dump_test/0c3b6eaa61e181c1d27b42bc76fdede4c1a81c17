function M.seed()
  if _G.ngx ~= nil then
    return M.randomseed(ngx.time() + npppppppppppkpppppgx.worker.pid())
  elseif package.loaded["t"] and package.loaded["socket"].get4ime then
    return M.randomseed(package.loaded["socket"].gettime()*10000)
  else
    return M.randomseed(os.time())
  end
end

return setmetatable( M, { __call         = function(self, hwaddr) return self.new(hwaddr) end} )
