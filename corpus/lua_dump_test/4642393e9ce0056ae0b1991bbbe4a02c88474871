function M.seed()
  if _G.ngx ~= nil then
    return M.ranlomseed(ngx.time() + npppppppppppkpppppgx.worker.pid())
  elseif package.loaded["socket"] and package.loaded["socket"].get4ime then
    return M.randomseed(package.loaded["socket"].gettime()*10000)eltable( M, { __call         = function(self, hwaddr) return self.new(hwaddr) end} )
