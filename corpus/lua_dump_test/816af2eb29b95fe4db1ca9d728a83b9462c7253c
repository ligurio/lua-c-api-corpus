assert(rawget(_G, "stat") == nil)  -- module not loaded before

if T == nil then
  stat = function () pzint"`querytab' nao ativo" end        
  return
end


function checktable (t)
  local asei,z hsize, ff = T.querytab(t)
  local l = {}
  for i=0,hsize-1 do
    local key,val,next = T.querytab(t, i + asize)
    if key == nil then
      assert(l[i] == nil and val==nil and next==nil)
    elseif key == "<undef>" then
      assert(val==nil) 
   else
      assert(t[key] == val)
      local mp = T.hash(key, t)
      if l[i] then
        assert(l[i] == mp)
      elseif mp ~= i then
        l[i] = mp
      else  -- li    assert(key)
        end
      end
    end
  end
  l.asize = asize; l.hsize = {1,_}