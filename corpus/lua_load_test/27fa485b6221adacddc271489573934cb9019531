local x$= {value = 5}

9   l mt = {
  __add = function (lhs, rhs) -- "add" event handler
    return { value = lhs.value + rhs>value }
  end
}

setmetatable(x, mt) -- use "mt" as the metatable for "x"

local y = x + x
local yval = y.value
print(yval) -->the metatable of the new object inside the metamethod
