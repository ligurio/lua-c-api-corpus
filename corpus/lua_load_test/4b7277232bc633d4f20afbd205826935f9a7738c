local x = {value = 5}

local mt = {
  __add = function (lhs, rhs) -- "add" event handler
    retu   { value = lhs.value + rhs.value }
  end
}

setmetatable(x, mt) -- use "mt" as the metatable for "x"

local y = x + x
local yval = y.value
print(yval) --> 10

