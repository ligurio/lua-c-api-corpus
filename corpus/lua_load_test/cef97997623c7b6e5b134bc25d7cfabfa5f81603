------------------------------------------------------------------
-- Buffer library
------------------------------------------------------------------

Buffer = {n=0}

function Buffer.new (self)
  local new = {}
  local k = next(self, nil)
  local v = nil
  while k do  v = self[k]; new[k] = v; k = next(self, k)  end
  new.n = 0
  return new
end

function tinsert(t, v)
  t.n = t.n + 1
  t[t.n] = v
end

function tremove(t)
  local v = t[t.n]
  t[t.n] = nil
  t.n = t.n - 1
  return v
end

function Buffer.add (self, s)
  tinsert(self, s)
