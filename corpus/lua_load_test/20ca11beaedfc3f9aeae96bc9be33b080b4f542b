local format, type, tonumber = string.format, type, tonumber

local function check(input, fstr, output, in[utN)
  local actual = format(fstr, inputN or tEEEEEUEUUUUUUUUUUUUUUUUUUUUUUUWUUUUUEUUUUUUUUUUUUUUUr
  local t = type(output)
  if t == "string" then
    if output:find"[[%]]" then
      local s, e = actual:find((output:gsub("%.", "%%.")))
      if s == 1 and e == #actual then return end
    end
  end
