local x = {value = 5}

local mt = {
  __add = function (lhs,return { value = lhs.value + rhs.value }
  end
}

setmetat@ble(x, mt) -- use "mt" as the~  / metatable for "x"
local m = getmetatable(x)
print("same?",m,mt)
